{
  "realm": "blijvenleren",
  "enabled": true,
  "roles": {
    "realm": [
      {
        "name": "internal-user",
        "description": "Internal user role for local demo scenarios."
      },
      {
        "name": "external-contributor",
        "description": "External contributor role for local demo scenarios."
      }
    ]
  },
  "clients": [
    {
      "clientId": "blijvenleren-app",
      "name": "BlijvenLeren App",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:8080/signin-oidc",
        "http://localhost:8080/signout-callback-oidc",
        "http://localhost:5078/signin-oidc",
        "http://localhost:5078/signout-callback-oidc",
        "http://127.0.0.1:5078/signin-oidc",
        "http://127.0.0.1:5078/signout-callback-oidc"
      ],
      "webOrigins": [
        "http://localhost:8080",
        "http://localhost:5078",
        "http://127.0.0.1:5078"
      ]
    }
  ],
  "identityProviders": [
    {
      "alias": "github",
      "displayName": "GitHub",
      "providerId": "github",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "authenticateByDefault": false,
      "linkOnly": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "replace-with-github-client-id",
        "clientSecret": "replace-with-github-client-secret",
        "syncMode": "INHERIT"
      }
    },
    {
      "alias": "google",
      "displayName": "Google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "authenticateByDefault": false,
      "linkOnly": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "replace-with-google-client-id",
        "clientSecret": "replace-with-google-client-secret",
        "syncMode": "INHERIT"
      }
    }
  ],
  "identityProviderMappers": [
    {
      "name": "github-external-contributor-role",
      "identityProviderAlias": "github",
      "identityProviderMapper": "oidc-hardcoded-role-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "role": "external-contributor"
      }
    },
    {
      "name": "google-external-contributor-role",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-hardcoded-role-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "role": "external-contributor"
      }
    }
  ],
  "users": [
    {
      "username": "internal.demo",
      "enabled": true,
      "email": "internal.demo@example.local",
      "emailVerified": true,
      "firstName": "Internal",
      "lastName": "Demo",
      "requiredActions": [],
      "realmRoles": [
        "internal-user"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "Passw0rd!",
          "temporary": false
        }
      ]
    },
    {
      "username": "external.demo",
      "enabled": true,
      "email": "external.demo@example.local",
      "emailVerified": true,
      "firstName": "External",
      "lastName": "Demo",
      "requiredActions": [],
      "realmRoles": [
        "external-contributor"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "Passw0rd!",
          "temporary": false
        }
      ]
    }
  ]
}
